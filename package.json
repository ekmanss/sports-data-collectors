{
  "name": "sports-data-collectors",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json && pnpm --filter @ekmanss/hltv check && pnpm --filter @ekmanss/5eplay check",
    "test": "tsx --test scripts/release.test.ts && pnpm --filter @ekmanss/hltv test && pnpm --filter @ekmanss/5eplay test",
    "test:live": "pnpm --filter @ekmanss/hltv test:live",
    "test:live:5eplay": "pnpm --filter @ekmanss/5eplay test:live",
    "test:live:5eplay:list": "pnpm --filter @ekmanss/5eplay test:live:list",
    "5eplay:md": "tsx packages/5eplay/src/cli.ts",
    "build": "pnpm --filter @ekmanss/hltv build && pnpm --filter @ekmanss/5eplay build",
    "verify": "pnpm check && pnpm test && pnpm build",
    "release": "tsx scripts/release.ts",
    "release:hltv": "tsx scripts/release.ts hltv",
    "release:5eplay": "tsx scripts/release.ts 5eplay"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  }
}
