{
  "name": "@ekmanss/hltv",
  "version": "20260712.2.0",
  "description": "Typed HLTV match-detail and live-match data collection with CloakBrowser.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "test": "tsx --test tests/match.test.ts",
    "test:live": "tsx tests/live.ts",
    "verify": "pnpm check && pnpm test && pnpm build",
    "prepack": "pnpm verify"
  },
  "dependencies": {
    "cloakbrowser": "0.4.10",
    "playwright-core": "1.61.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ekmanss/sports-data-collectors.git",
    "directory": "packages/hltv"
  },
  "homepage": "https://github.com/ekmanss/sports-data-collectors/tree/main/packages/hltv#readme",
  "bugs": {
    "url": "https://github.com/ekmanss/sports-data-collectors/issues"
  },
  "author": "ekmanss",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
