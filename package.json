{
  "name": "sports-data-collectors",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json && pnpm --filter @ekmanss/hltv check",
    "test": "pnpm --filter @ekmanss/hltv test",
    "test:live": "pnpm --filter @ekmanss/hltv test:live",
    "build": "pnpm --filter @ekmanss/hltv build",
    "verify": "pnpm check && pnpm test && pnpm build",
    "release": "tsx scripts/release.ts"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  }
}
